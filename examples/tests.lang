extern_def println;
extern_def test_assert;
extern_def test_assert_eq;

begin_def add x, y, to;
	*to = x + y;
end_def


link_attr section tests;
public begin_def test_add;
	to = 0;

	add 1, 2, &to;
	test_assert_eq to, 3;

	add 21, 21, &to;
	test_assert_eq to, 42;

end_def

link_attr section tests;
public begin_def test_add2;
	to = 0;

	add 0, 3, &to;
	test_assert_eq to, 3;

	add 20, 22, &to;
	test_assert_eq to, 42;

end_def

link_attr section tests;
begin_def failure;
	test_assert_eq 1, 2;
end_def


public begin_def main;
	print_str "hello there, to run the tests, pass --test to the compiler flags";
end_def
