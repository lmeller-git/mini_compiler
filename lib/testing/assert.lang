# Utilities for testing functions
# Using these functions instead of standard assert, allows the program to continue after a failure

extern_def _test_state_set_failed;
extern_def println;

public begin_def test_assert x;
	if x; goto exit;
	_test_state_set_failed;
	print_str "\nassertion failed\n\n";
	label exit;
end_def

public begin_def test_assert_eq a, b;
	if a == b; goto exit;
	_test_state_set_failed;
	print_str "\nassertion failed\n left != right\n";
	print_str "left: ";
	println a;
	print_str "right: ";
	println b;
	print_str "\n";
	label exit;
end_def
