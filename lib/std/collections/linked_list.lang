extern_def panic;
extern_def println;
extern_def call_calloc;
extern_def call_free;
extern_def call_memcpy;
extern_def call_realloc;

# Linked list over nodes {next^prev, payload} with List {head, tail, len}
# A list is a ptr to some heap allocated List

# Usage: linked_list &to;
public begin_def linked_list to;
	call_calloc to, 3, 8;
end_def

# Usage: allocate_node &to;
public begin_def allocate_node to;
	call_calloc to, 2, 8;
end_def

# Usage: ll_len list, &to;
public begin_def ll_len list, to;
	*to = *(list + 16);
end_def

begin_def __bound_violation len, idx, msg;
	print_str "linked list bound violation:\nthe len is: ";
	print len;
	print_str " but the index is: ";
	println idx;
	panic msg;
end_def

begin_def ll_drop_node node;
	call_free node;
end_def

# Usage: ll_push_front list, value;
public begin_def ll_push_front list, value;
	_len_bytes = list + 16;
	node = 0;
	allocate_node &node;
	payload = node + 8;
	*payload = value;

	if !*_len_bytes; goto empty;

	# non empty
	**list = **list ^ node;
	*node = *list;
	*list = node;
	goto exit;

	label empty;
	*list = node;
	tail = list + 8;
	*tail = node;

	label exit;
	*_len_bytes = *_len_bytes + 1;
end_def

# Usage: ll_push_tail list, value;
public begin_def ll_push_tail list, value;
	_len_bytes = list + 16;
	node = 0;
	allocate_node &node;
	payload = node + 8;
	*payload = value;

	if !*_len_bytes; goto empty;

	# non empty
	tail_ptr = list + 8;
	**tail_ptr = **tail_ptr ^ node;
	*node = *tail_ptr;
	*tail_ptr = node;
	goto exit;

	label empty;
	*list = node;
	tail = list + 8;
	*tail = node;

	label exit;
	*_len_bytes = *_len_bytes + 1;
end_def

# Usage: ll_pop_front list, &to;
public begin_def ll_pop_front list, to;
	_len_bytes = list + 16;
	if *_len_bytes; goto non_empty;
	*to = 0;
	goto exit;

	label non_empty;
	if *_len_bytes == 1; goto one;
	# list -> head -> next
	# _ -> 0 ^ next -> prev ^ next
	old_head = *list;
	*to = *(old_head + 8);
	***list = ***list ^ old_head;
	*list = **list;
	*_len_bytes = *_len_bytes - 1;
	ll_drop_node old_head;
	goto exit;

	label one;
	*to = *(*list + 8);
	ll_drop_node *list;
	*list = 0;
	end = list + 8;
	*end = 0;
	*_len_bytes = 0;

	label exit;
end_def

# Usage: ll_pop_tail list, &to;
public begin_def ll_pop_tail list, to;
	_len_bytes = list + 16;
	if *_len_bytes; goto non_empty;
	*to = 0;
	goto exit;

	label non_empty;
	if *_len_bytes == 1; goto one;
	# list -> head -> next
	# _ -> 0 ^ next -> prev ^ next
	old_tail = list + 8;
	old_tail_node = *old_tail;
	*to = *(*old_tail + 8);
	***old_tail = ***old_tail ^ *old_tail;
	*old_tail = **old_tail;
	*_len_bytes = *_len_bytes - 1;
	ll_drop_node old_tail_node;
	goto exit;

	label one;
	*to = *(*(list + 8) + 8);
	ll_drop_node *(list + 8);
	*list = 0;
	end = list + 8;
	*end = 0;
	*_len_bytes = 0;

	label exit;
end_def

begin_def __get_node_pair list, at, prev_node, next_node;
	if !(*(list + 16) > at); __bound_violation *(list + 16), at, "in __get_node";
	prev = 0;
	i = 0;
	if (*(list + 16) / 2) < at; goto greater;

	next = *list;
	is_forward = 1;
	goto walk;

	label greater;
	is_forward = 0;
	next = *(list + 8);
	at = *(list + 16) - at + 1;

	label walk;
	if at == i; goto cleanup;
	current = *next ^ prev;
	prev = next;
	next = current;
	i = i + 1;
	goto walk;

	label cleanup;
	if is_forward; goto exit_forward;

	*prev_node = *next ^ prev;
	*next_node = next;
	goto exit;

	label exit_forward;
	*next_node = next;
	*prev_node = prev;

	label exit;
end_def

# Usage: ll_get list, at, &to;
begin_def ll_get list, at, to;
	if !(*(list + 16) > at); __bound_violation *(list + 16), at, "in get";
	if !at; goto head;
	if at == *(list + 16); goto tail;

	prev = 0;
	node = 0;
	__get_node_pair list, at, &prev, &node;
	*to = *(node + 8);
	goto exit;

	label tail;
	*to = *(*(list + 8) + 8);
	goto exit;

	label head;
	*to = *(*list + 8);

	label exit;
end_def

# Usage: ll_set list, at, value;
begin_def ll_set list, at, value;
	if !(*(list + 16) > at); __bound_violation *(list + 16), at, "in set";
	if !at; goto head;
	if at == *(list + 16); goto tail;

	prev = 0;
	node = 0;
	__get_node_pair list, at, &prev, &node;
	payload = node + 8;
	*payload = value;
	goto exit;

	label tail;
	payload = (*(list + 8) + 8);
	*payload = value;
	goto exit;

	label head;
	payload = *list + 8;
	*payload = value;

	label exit;
end_def

# Usage: ll_insert list, at, value;
public begin_def ll_insert list, at, value;
	_len_bytes = list + 16;
	if *_len_bytes < at; __bound_violation *_len_bytes, at, "in insert";
	if !at; goto front;
	if *_len_bytes == at; goto tail;

	node = 0;
	allocate_node &node;
	payload = node + 8;
	*payload = value;

	prev = 0;
	current = 0;
	__get_node_pair list, at, &prev, &current;

	*node = prev ^ current;
	*prev = *prev ^ current ^ node;
	*current = *current ^ prev ^ node;
	*_len_bytes = *_len_bytes + 1;
	goto exit;

	label front;
	ll_push_front list, value;
	goto exit;
	label tail;
	ll_push_tail list, value;

	label exit;
end_def

# Usage: ll_remove list, at, &to;
public begin_def ll_remove list, at, to;
	_len_bytes = list + 16;
	if !(*_len_bytes > at); __bound_violation *_len_bytes, at, "in remove";
	if !at; goto front;
	if *_len_bytes == at + 1; goto tail;

	node = 0;
	prev = 0;
	__get_node_pair list, at, &prev, &node;

	next = *node ^ prev;
	*prev = *prev ^ node ^ next;
	*next = *next ^ node ^ prev;

	*to = *(node + 8);
	ll_drop_node node;
	*_len_bytes = *_len_bytes - 1;
	goto exit;

	label tail;
	ll_pop_tail list, to;
	goto exit;
	label front;
	ll_pop_front list, to;

	label exit;
end_def

# Usage: print_ll list;
public begin_def print_ll list;
	print_str "[ ";
	next = *list;
	prev = 0;

	label walk;
	if !next; goto exit;
	if prev; print_str " , ";
	print *(next + 8);
	current = *next ^ prev;
	prev = next;
	next = current;
	goto walk;

	label exit;
	print_str " ]";
end_def

# Usage: ll_drop_list list;
public begin_def ll_drop_list list;
	next = *list;
	prev = 0;

	label walk;
	if !next; goto exit;
	current = *next ^ prev;
	prev = next;
	next = current;
	ll_drop_node prev;
	goto walk;

	label exit;
	call_free list;
end_def


