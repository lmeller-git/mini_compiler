begin_def test_ll_len;
    l = 0;
    linked_list &l;

    len = 0;
    ll_len l, &len;
    test_assert_eq len, 0;

    ll_push_front l, 10;
    ll_len l, &len;
    test_assert_eq len, 1;

    ll_drop_list l;
end_def

