end_def

begin_def __insert_between prev, next, value;
	node = 0;
	allocate_node &node;
	*node = prev ^ next;
	payload = node + 8;
	*payload = value;
	*next = *next ^ prev ^ node;
	*prev = *prev ^ next ^ node;
end_def

